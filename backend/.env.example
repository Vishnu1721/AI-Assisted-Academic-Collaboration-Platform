# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Server
PORT=3001

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=MINI_PROJECT

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=2h

# Registration domain restriction (set empty to allow any domain)
ALLOWED_EMAIL_DOMAIN=ssn.edu.in

# AI code analysis (optional). If unset, the service falls back to a local heuristic analyzer.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
